rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath(churchId) {
      return /databases/(default)/documents/churches/$(churchId)/members/$(request.auth.uid);
    }

    function memberExists(churchId) {
      return signedIn() && firestore.exists(memberPath(churchId));
    }

    function isActiveMember(churchId) {
      return memberExists(churchId)
        && firestore.get(memberPath(churchId)).data.get('isActive', true)
          == true;
    }

    function memberRole(churchId) {
      return firestore.get(memberPath(churchId)).data.get('role', 'member');
    }

    function isApprovedMember(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) != 'visitor';
    }

    function isAdmin(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) in ['admin', 'pastor'];
    }

    function resourcePublished(churchId, resourceId) {
      return firestore.exists(
        /databases/(default)/documents/churches/$(churchId)/resources/$(resourceId)
      )
      && firestore.get(
        /databases/(default)/documents/churches/$(churchId)/resources/$(resourceId)
      ).data.get('published', false) == true;
    }

    match /churches/{churchId}/member_profile_photos/{memberId}/{allPaths=**} {
      allow read: if isApprovedMember(churchId);

      allow create, update: if (
          (
            isApprovedMember(churchId)
            && request.auth.uid == memberId
          )
          || isAdmin(churchId)
        )
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');

      allow delete: if (
        isApprovedMember(churchId)
        && request.auth.uid == memberId
      )
      || isAdmin(churchId);
    }

    match /churches/{churchId}/home/{fileName} {
      allow read: if true;

      allow create, update: if isAdmin(churchId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');

      allow delete: if isAdmin(churchId);
    }

    match /churches/{churchId}/resources/{resourceId}/{allPaths=**} {
      allow read: if resourcePublished(churchId, resourceId)
        || isAdmin(churchId);

      allow create, update: if isAdmin(churchId)
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType != null
        && (
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/epub.*')
          || request.resource.contentType.matches('application/msword')
          || request.resource.contentType.matches('application/vnd.*')
          || request.resource.contentType.matches('text/plain')
          || request.resource.contentType.matches('image/.*')
        );

      allow delete: if isAdmin(churchId);
    }

    match /churches/{churchId}/media/{allPaths=**} {
      // Existing public media paths do not contain the Firestore media ID,
      // so publication-aware file authorization requires a future path migration.
      allow read: if true;

      allow create, update: if isAdmin(churchId)
        && request.resource.size < 500 * 1024 * 1024
        && request.resource.contentType != null
        && (
          request.resource.contentType.matches('video/.*')
          || request.resource.contentType.matches('audio/.*')
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('application/pdf')
        );

      allow delete: if isAdmin(churchId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
