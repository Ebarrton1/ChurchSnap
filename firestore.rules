rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserId() {
      return request.auth.uid;
    }

    function memberPath(churchId, memberId) {
      return /databases/$(database)/documents/churches/$(churchId)/members/$(memberId);
    }

    function memberExists(churchId) {
      return signedIn() && exists(memberPath(churchId, currentUserId()));
    }

    function memberRole(churchId) {
      return get(memberPath(churchId, currentUserId())).data.get('role', 'member');
    }

    function isActiveMember(churchId) {
      return memberExists(churchId)
        && get(memberPath(churchId, currentUserId())).data.get('isActive', true) == true;
    }

    function isVisitor(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) == 'visitor';
    }

    function isApprovedMember(churchId) {
      return isActiveMember(churchId)
        && !isVisitor(churchId);
    }

    function validRole(role) {
      return role in [
        'visitor',
        'member',
        'volunteer',
        'groupLeader',
        'ministryLeader',
        'pastor',
        'admin'
      ];
    }

    function validNotificationAudience(audience) {
      return audience == 'all' || validRole(audience);
    }

    function canReadNotification(churchId, data) {
      return isAdmin(churchId)
        || (
          isActiveMember(churchId)
          && data.get('targetRole', 'all')
            in ['all', memberRole(churchId)]
        );
    }

    function isAdmin(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) in ['admin', 'pastor'];
    }

    function isMinistryLeader(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) == 'ministryLeader';
    }

    function isGroupLeader(churchId) {
      return isActiveMember(churchId)
        && memberRole(churchId) == 'groupLeader';
    }

    function isLeader(churchId) {
      return isAdmin(churchId)
        || isMinistryLeader(churchId)
        || isGroupLeader(churchId);
    }

    function ministryExists(churchId, ministryId) {
      return ministryId is string
        && ministryId.size() > 0
        && exists(
          /databases/$(database)/documents/churches/$(churchId)/ministries/$(ministryId)
        );
    }

    function leadsMinistry(churchId, ministryId) {
      return isMinistryLeader(churchId)
        && ministryExists(churchId, ministryId)
        && get(
          /databases/$(database)/documents/churches/$(churchId)/ministries/$(ministryId)
        ).data.get('leaderId', '') == currentUserId();
    }

    function ownsAttendanceRecord(data) {
      return signedIn()
        && (
          data.get('memberId', '') == currentUserId()
          || data.get('userId', '') == currentUserId()
        );
    }

    function validSelfAttendanceRecord(data) {
      return signedIn()
        && (
          data.get('memberId', '') == currentUserId()
          || data.get('userId', '') == currentUserId()
        )
        && data.get('memberId', '') in ['', currentUserId()]
        && data.get('userId', '') in ['', currentUserId()];
    }

    function churchPath(churchId) {
      return /databases/$(database)/documents/churches/$(churchId);
    }

    function churchAcceptsVisitors(churchId) {
      return churchId is string
        && churchId.size() > 0
        && exists(churchPath(churchId))
        && get(churchPath(churchId)).data.get('isActive', true) == true
        && get(churchPath(churchId)).data.get(
          'visitorAccessEnabled',
          true
        ) == true;
    }

    match /userChurchLinks/{userId} {
      allow read, delete: if signedIn()
        && userId == currentUserId();

      allow create, update: if signedIn()
        && userId == currentUserId()
        && request.resource.data.keys().hasOnly([
          'churchId',
          'updatedAt'
        ])
        && request.resource.data.get('churchId', '') is string
        && request.resource.data.get('churchId', '').size() > 0
        && (
          exists(
            memberPath(
              request.resource.data.get('churchId', ''),
              currentUserId()
            )
          )
          || churchAcceptsVisitors(
            request.resource.data.get('churchId', '')
          )
        );
    }

    match /churches/{churchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin(churchId);

      match /members/{memberId} {
        allow get: if signedIn()
          && (
            memberId == currentUserId()
            || isApprovedMember(churchId)
          );

        allow list: if isApprovedMember(churchId);

        allow create: if (
          signedIn()
          && memberId == currentUserId()
          && request.resource.data.get('id', memberId) == memberId
          && request.resource.data.get('churchId', churchId) == churchId
          && request.resource.data.get('role', 'visitor') == 'visitor'
          && request.resource.data.get('isActive', true) == true
          && churchAcceptsVisitors(churchId)
        )
        || (
          isAdmin(churchId)
          && validRole(request.resource.data.get('role', 'member'))
        );

        allow update: if (
          signedIn()
          && memberId == currentUserId()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'id',
            'churchId',
            'displayName',
            'email',
            'phone',
            'photoUrl',
            'role',
            'isActive',
            'isEmailVerified',
            'fcmToken',
            'fcmTokenUpdatedAt',
            'updatedAt'
          ])
          && request.resource.data.get('id', memberId)
            == resource.data.get('id', memberId)
          && request.resource.data.get('id', memberId) == memberId
          && request.resource.data.get('churchId', churchId)
            == resource.data.get('churchId', churchId)
          && request.resource.data.get('churchId', churchId) == churchId
          && request.resource.data.get('role', 'member')
            == resource.data.get('role', 'member')
          && request.resource.data.get('isActive', true)
            == resource.data.get('isActive', true)
        )
        || (
          isAdmin(churchId)
          && memberId != currentUserId()
          && (
            request.resource.data.get('role', 'member')
              == resource.data.get('role', 'member')
            || validRole(request.resource.data.get('role', 'member'))
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'displayName',
            'email',
            'phone',
            'photoUrl',
            'role',
            'isActive',
            'updatedAt'
          ])
        );

        allow delete: if isAdmin(churchId)
          && memberId != currentUserId();

        match /sermonBookmarks/{sermonId} {
          allow read, create, update, delete: if isApprovedMember(churchId)
            && memberId == currentUserId();
        }
      }

      match /memberPrivateProfiles/{memberId} {
        allow read: if (
          isApprovedMember(churchId)
          && memberId == currentUserId()
        )
        || isAdmin(churchId);

        allow create, update: if (
          (
            isApprovedMember(churchId)
            && memberId == currentUserId()
          )
          || isAdmin(churchId)
        )
        && request.resource.data.keys().hasOnly([
            'firstName',
            'middleName',
            'lastName',
            'addressLine1',
            'addressLine2',
            'city',
            'stateOrProvince',
            'postalCode',
            'country',
            'membershipDate',
            'marriageDate',
            'dateOfBirth',
            'maritalStatus',
            'gender',
            'updatedAt'
          ]);

        allow delete: if (
          isApprovedMember(churchId)
          && memberId == currentUserId()
        )
        || isAdmin(churchId);
      }

      match /settings/{settingId} {
        allow read: if settingId == 'homeAppearance';

        allow create, update: if settingId == 'homeAppearance'
          && isAdmin(churchId)
          && request.resource.data.keys().hasOnly([
            'backgroundImageUrl',
            'storagePath',
            'updatedAt'
          ]);

        allow delete: if settingId == 'homeAppearance'
          && isAdmin(churchId);
      }

      match /announcements/{announcementId} {
        allow read: if resource.data.get('published', false) == true
          || isApprovedMember(churchId);

        allow create, update, delete: if isAdmin(churchId);
      }

      match /events/{eventId} {
        allow read: if resource.data.get('published', false) == true
          || isApprovedMember(churchId);

        allow create, delete: if isAdmin(churchId);

        allow update: if isAdmin(churchId)
          || (
            isApprovedMember(churchId)
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['attendeeIds', 'rsvpCount'])
            && request.resource.data.get('rsvpCount', 0)
              == request.resource.data.get('attendeeIds', []).size()
            && (
              (
                !(currentUserId() in resource.data.get('attendeeIds', []))
                && currentUserId()
                  in request.resource.data.get('attendeeIds', [])
                && request.resource.data.get('attendeeIds', []).size()
                  == resource.data.get('attendeeIds', []).size() + 1
                && request.resource.data.get('attendeeIds', [])
                  .hasAll(resource.data.get('attendeeIds', []))
              )
              || (
                currentUserId()
                  in resource.data.get('attendeeIds', [])
                && !(currentUserId()
                  in request.resource.data.get('attendeeIds', []))
                && request.resource.data.get('attendeeIds', []).size() + 1
                  == resource.data.get('attendeeIds', []).size()
                && resource.data.get('attendeeIds', [])
                  .hasAll(request.resource.data.get('attendeeIds', []))
              )
            )
          );
      }

      match /sermons/{sermonId} {
        allow read: if resource.data.get('published', false) == true
          || isAdmin(churchId);

        allow create, update, delete: if isAdmin(churchId);
      }

      match /prayer_requests/{prayerId} {
        allow read: if resource.data.get('published', false) == true
          || isLeader(churchId);

        allow create: if isApprovedMember(churchId);
        allow update, delete: if isLeader(churchId);
      }

      match /media/{mediaId} {
        allow read: if resource.data.get('published', false) == true
          || isApprovedMember(churchId);

        allow create, update, delete: if isAdmin(churchId);
      }

      match /eventCheckIns/{checkInId} {
        allow read: if isAdmin(churchId)
          || (
            isApprovedMember(churchId)
            && ownsAttendanceRecord(resource.data)
          );

        allow create: if isAdmin(churchId)
          || (
            isApprovedMember(churchId)
            && validSelfAttendanceRecord(request.resource.data)
          );

        allow update, delete: if isAdmin(churchId);
      }

      match /attendance/{attendanceId} {
        allow read: if isAdmin(churchId)
          || (
            isApprovedMember(churchId)
            && ownsAttendanceRecord(resource.data)
          );

        allow create: if isAdmin(churchId)
          || (
            isApprovedMember(churchId)
            && validSelfAttendanceRecord(request.resource.data)
          );

        allow update, delete: if isAdmin(churchId);
      }

      match /settings/{settingId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin(churchId);
      }

      match /notifications/{notificationId} {
        allow get, list: if isApprovedMember(churchId)
          && canReadNotification(churchId, resource.data);

        allow create: if isAdmin(churchId)
          && validNotificationAudience(
            request.resource.data.get('targetRole', 'all')
          )
          && request.resource.data.get('title', '') is string
          && request.resource.data.get('title', '').size() > 0
          && request.resource.data.get('body', '') is string
          && request.resource.data.get('body', '').size() > 0;

        allow update: if isAdmin(churchId)
          && validNotificationAudience(
            request.resource.data.get('targetRole', 'all')
          );

        allow delete: if isAdmin(churchId);
      }

      match /ministries/{ministryId} {
        allow read: if isApprovedMember(churchId);

        allow create: if isAdmin(churchId)
          || (
            isMinistryLeader(churchId)
            && request.resource.data.get('leaderId', '') == currentUserId()
          );

        allow update: if isAdmin(churchId)
          || (
            isMinistryLeader(churchId)
            && resource.data.get('leaderId', '') == currentUserId()
            && request.resource.data.get('leaderId', '') == currentUserId()
          );

        allow delete: if isAdmin(churchId)
          || (
            isMinistryLeader(churchId)
            && resource.data.get('leaderId', '') == currentUserId()
          );
      }

      match /small_groups/{groupId} {
        allow read: if isApprovedMember(churchId);

        allow create: if isAdmin(churchId)
          || (
            isGroupLeader(churchId)
            && request.resource.data.get('leaderId', '') == currentUserId()
          );

        allow update: if isAdmin(churchId)
          || (
            isGroupLeader(churchId)
            && resource.data.get('leaderId', '') == currentUserId()
            && request.resource.data.get('leaderId', '') == currentUserId()
          );

        allow delete: if isAdmin(churchId)
          || (
            isGroupLeader(churchId)
            && resource.data.get('leaderId', '') == currentUserId()
          );
      }

      match /volunteer_assignments/{assignmentId} {
        allow read: if isAdmin(churchId)
          || (
            isApprovedMember(churchId)
            && resource.data.get('memberId', '') == currentUserId()
          )
          || leadsMinistry(
            churchId,
            resource.data.get('ministryId', '')
          );

        allow create: if isAdmin(churchId)
          || leadsMinistry(
            churchId,
            request.resource.data.get('ministryId', '')
          );

        allow update: if isAdmin(churchId)
          || (
            leadsMinistry(
              churchId,
              resource.data.get('ministryId', '')
            )
            && request.resource.data.get('ministryId', '')
              == resource.data.get('ministryId', '')
          );

        allow delete: if isAdmin(churchId)
          || leadsMinistry(
            churchId,
            resource.data.get('ministryId', '')
          );
      }

      match /giving_funds/{fundId} {
        allow read: if true;
        allow create, update, delete: if isAdmin(churchId);
      }

      match /donations/{donationId} {
        allow read: if isAdmin(churchId)
          || (
            isApprovedMember(churchId)
            && resource.data.get('memberId', '') == currentUserId()
          );

        allow create, update: if isAdmin(churchId);
        allow delete: if false;
      }

      match /giving/{givingId} {
        allow read, write: if false;
      }
    }
  }
}

