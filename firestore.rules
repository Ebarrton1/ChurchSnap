rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function memberExists(churchId) {
      return signedIn()
        && exists(
          /databases/$(database)/documents/churches/$(churchId)/members/$(request.auth.uid)
        );
    }

    function isAdmin(churchId) {
      return memberExists(churchId)
        && (
          get(
            /databases/$(database)/documents/churches/$(churchId)/members/$(request.auth.uid)
          ).data.role == 'admin'
          ||
          get(
            /databases/$(database)/documents/churches/$(churchId)/members/$(request.auth.uid)
          ).data.role == 'pastor'
        );
    }

    function isLeader(churchId) {
      return isAdmin(churchId)
        || (
          memberExists(churchId)
          && (
            get(
              /databases/$(database)/documents/churches/$(churchId)/members/$(request.auth.uid)
            ).data.role == 'ministryLeader'
            ||
            get(
              /databases/$(database)/documents/churches/$(churchId)/members/$(request.auth.uid)
            ).data.role == 'groupLeader'
          )
        );
    }

    match /churches/{churchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin(churchId);

      match /members/{memberId} {
        allow read: if signedIn();

        allow create: if signedIn()
          && memberId == request.auth.uid
          && request.resource.data.role in ['member', 'visitor'];

        allow update: if (
          isAdmin(churchId)
          && memberId != request.auth.uid
        )
        || (
          signedIn()
          && memberId == request.auth.uid
          && request.resource.data.role == resource.data.role
        );

        allow delete: if isAdmin(churchId);

        match /sermonBookmarks/{sermonId} {
          allow read, create, update, delete: if signedIn()
            && memberId == request.auth.uid;
        }
      }

      match /memberPrivateProfiles/{memberId} {
        allow read: if signedIn()
          && (
            memberId == request.auth.uid
            || isAdmin(churchId)
          );

        allow create, update: if signedIn()
          && (
            memberId == request.auth.uid
            || isAdmin(churchId)
          )
          && request.resource.data.keys().hasOnly([
            'dateOfBirth',
            'maritalStatus',
            'gender',
            'updatedAt'
          ]);

        allow delete: if signedIn()
          && (
            memberId == request.auth.uid
            || isAdmin(churchId)
          );
      }
      match /announcements/{announcementId} {
        allow read: if signedIn()
          || resource.data.published == true;

        allow create, update, delete: if isAdmin(churchId);
      }

      match /events/{eventId} {
        allow read: if signedIn()
          || resource.data.published == true;

        allow create, delete: if isAdmin(churchId);

        allow update: if isAdmin(churchId)
          || (
            signedIn()
            && memberExists(churchId)
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['attendeeIds', 'rsvpCount'])
            && request.resource.data.get('rsvpCount', 0)
              == request.resource.data.get('attendeeIds', []).size()
            && (
              (
                !(request.auth.uid in resource.data.get('attendeeIds', []))
                && request.auth.uid
                  in request.resource.data.get('attendeeIds', [])
                && request.resource.data.get('attendeeIds', []).size()
                  == resource.data.get('attendeeIds', []).size() + 1
                && request.resource.data.get('attendeeIds', [])
                  .hasAll(resource.data.get('attendeeIds', []))
              )
              || (
                request.auth.uid
                  in resource.data.get('attendeeIds', [])
                && !(request.auth.uid
                  in request.resource.data.get('attendeeIds', []))
                && request.resource.data.get('attendeeIds', []).size() + 1
                  == resource.data.get('attendeeIds', []).size()
                && resource.data.get('attendeeIds', [])
                  .hasAll(request.resource.data.get('attendeeIds', []))
              )
            )
          );
      }

      match /sermons/{sermonId} {
        allow read: if resource.data.published == true
          || isAdmin(churchId);

        allow create, update, delete: if isAdmin(churchId);
      }

      match /prayer_requests/{prayerId} {
        allow read: if resource.data.published == true
          || isLeader(churchId);

        allow create: if signedIn();
        allow update, delete: if isLeader(churchId);
      }

      match /media/{mediaId} {
        allow read: if signedIn()
          || resource.data.published == true;

        allow create, update, delete: if isAdmin(churchId);
      }

      match /eventCheckIns/{checkInId} {
        allow read, create: if signedIn();
        allow update, delete: if isAdmin(churchId);
      }

      match /attendance/{attendanceId} {
        allow read, create: if signedIn();
        allow update, delete: if isAdmin(churchId);
      }

      match /notifications/{notificationId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin(churchId);
      }

      match /ministries/{ministryId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin(churchId)
          || (
            memberExists(churchId)
            && get(
              /databases/$(database)/documents/churches/$(churchId)/members/$(request.auth.uid)
            ).data.role == 'ministryLeader'
          );
      }

      match /small_groups/{groupId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin(churchId)
          || (
            memberExists(churchId)
            && get(
              /databases/$(database)/documents/churches/$(churchId)/members/$(request.auth.uid)
            ).data.role == 'groupLeader'
          );
      }

      match /volunteer_assignments/{assignmentId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin(churchId)
          || (
            memberExists(churchId)
            && get(
              /databases/$(database)/documents/churches/$(churchId)/members/$(request.auth.uid)
            ).data.role == 'ministryLeader'
          );
      }

      match /giving_funds/{fundId} {
        allow read: if true;
        allow create, update, delete: if isAdmin(churchId);
      }

      match /donations/{donationId} {
        allow read: if isAdmin(churchId)
          || (
            signedIn()
            && resource.data.memberId == request.auth.uid
          );

        allow create, update: if isAdmin(churchId);
        allow delete: if false;
      }

      match /giving/{givingId} {
        allow read, write: if false;
      }
    }
  }
}
